{
  "name": "pdfing-pro",
  "version": "1.0.0-beta.1",
  "private": true,
  "main": "electron/main.cjs",
  "engines": {
    "node": ">=18.18.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "node scripts/clean-pwa-artifacts.mjs && next dev",
    "dev:clean": "node scripts/clean-pwa-artifacts.mjs && node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev",
    "build": "npm run build:web",
    "build:web": "next build",
    "build:desktop": "node scripts/build-desktop.mjs",
    "start": "next start",
    "desktop": "electron .",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "node scripts/smoke-test-touch-tools.mjs",
    "postinstall": "node scripts/copy-pdfjs-worker.mjs && node scripts/copy-material-symbols-font.mjs && node scripts/ensure-puppeteer-browser.mjs && node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@pdfsmaller/pdf-encrypt-lite": "^1.0.2",
    "docx": "^8.5.0",
    "heic2any": "^0.0.4",
    "jszip": "^3.10.1",
    "material-symbols": "^0.45.2",
    "modern-pdf-lib": "^0.26.0",
    "next": "15.5.19",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "4.10.38",
    "pptxgenjs": "^4.0.1",
    "puppeteer": "^24.43.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.5",
    "tesseract.js": "^5.1.1",
    "utif": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "^8",
    "eslint-config-next": "15.5.19",
    "postcss": "8.5.12",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "vitest": "^3.2.6"
  },
  "build": {
    "appId": "com.pdfingpro",
    "productName": "Pdfing Pro",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      ".next/**/*",
      "app/**/*",
      "assets/**/*",
      "components/**/*",
      "lib/**/*",
      "locales/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json",
      "next.config.mjs"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "overrides": {
    "brace-expansion": "^5.0.6",
    "esbuild": "^0.28.1",
    "form-data": "^4.0.6",
    "glob": "^10.4.6",
    "js-yaml": "^4.1.2",
    "postcss": "8.5.12",
    "serialize-javascript": "^7.0.6",
    "tar": "^7.5.16",
    "tmp": "^0.2.6"
  }
}
